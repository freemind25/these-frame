{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "ThesisFrame default capabilities for desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-execute",
    "shell:allow-spawn",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "node", "args": true },
        { "name": "bun", "args": true }
      ]
    }
  ]
}
